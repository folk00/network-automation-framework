! ----------------------------------------------------------------------
! {{ host.hostname }} — generated by network-automation-framework
! ----------------------------------------------------------------------
hostname {{ host.hostname }}
!
interface Loopback{{ host.loopback.id }}
 description Router-ID
 ip address {{ host.loopback.ip }} {{ host.loopback.mask }}
 ip ospf {{ host.ospf_process_id }} area 0
!
{% for i in host.interfaces %}
interface {{ i.name }}
 description {{ i.description }}
 ip address {{ i.ip }} {{ i.mask }}
{% if i.ospf_authentication is defined and i.ospf_authentication == 'md5' %}
 ip ospf message-digest-key {{ i.ospf_key_id }} md5 {{ i.ospf_key }}
 ip ospf authentication message-digest
{% endif %}
 ip ospf {{ host.ospf_process_id }} area {{ i.ospf_area }}
 no shutdown
!
{% endfor %}
router ospf {{ host.ospf_process_id }}
 router-id {{ host.ospf_router_id }}
 area 0 authentication message-digest
 passive-interface default
 no passive-interface Loopback{{ host.loopback.id }}
{% for i in host.interfaces %}
 no passive-interface {{ i.name }}
{% endfor %}
!
end
