---
profile: production

exclude_paths:
  - .github/
  - vault/secrets.yml      # encrypted, lint can't parse
  - rendered/
  - backups/

skip_list:
  - yaml[line-length]      # readability over wraparound for long IOS lines
  - yaml[colons]           # inventory inline maps intentionally align values
  - yaml[commas]           # inventory inline lists favor readability
  - yaml[braces]           # inventory inline maps favor compact topology data
  - name[play]             # compact demo playbooks are self-describing by filename
  - var-naming             # shared demo vars intentionally stay vendor-neutral
  - jinja[spacing]         # keep long generated-path expressions readable

warn_list:
  - experimental
  - role-name              # role names use snake_case which lint complains about
