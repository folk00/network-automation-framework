! ----------------------------------------------------------------------
! {{ inventory_hostname }} — generated by role ospf_edge (Arista EOS variant)
! ----------------------------------------------------------------------
hostname {{ inventory_hostname }}
!
interface Loopback{{ loopback.id }}
   description Router-ID
   ip address {{ loopback.ip }}/{{ loopback.prefix | default(32) }}
   ip ospf area 0
!
{% for i in interfaces %}
interface {{ i.name }}
   description {{ i.description }}
   no switchport
   ip address {{ i.ip }}/{{ i.prefix }}
{% if i.ospf_authentication is defined and i.ospf_authentication == 'md5' %}
   ip ospf message-digest-key {{ i.ospf_key_id }} md5 {{ i.ospf_key }}
   ip ospf authentication message-digest
{% endif %}
   ip ospf area {{ i.ospf_area }}
   no shutdown
!
{% endfor %}
router ospf {{ ospf_process_id }}
   router-id {{ ospf_router_id }}
{% if ospf_passive_default %}
   passive-interface default
   no passive-interface Loopback{{ loopback.id }}
{% for i in interfaces %}
   no passive-interface {{ i.name }}
{% endfor %}
{% endif %}
!
end
